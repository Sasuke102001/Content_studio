{
  "name": "polynovea-carousel-desktop",
  "version": "1.0.3",
  "description": "PolyNovea Carousel & Content Desktop App",
  "main": "dist/main/index.js",
  "author": "PolyNovea Team",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:motion",
    "build:motion": "node motion/scripts/bundle.js",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "setup-python": "node scripts/setup-python.js",
    "package": "npm run build && npm run setup-python && electron-builder --win --dir",
    "dist": "npm run build && npm run setup-python && electron-builder --win",
    "release": "npm run build && npm run setup-python && electron-builder --win --publish always"
  },
  "dependencies": {
    "@remotion/renderer": "4.0.473",
    "@supabase/supabase-js": "^2.107.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^26.15.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.polynovea.carousel",
    "productName": "PolyNovea Content Studio",
    "icon": "Logos/polynovea-content-studio.ico",
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist/**/*",
      "!dist/motion-bundle/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/motion-bundle",
        "to": "motion-bundle",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "engine",
        "to": "engine",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "mode_packs",
        "to": "mode_packs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "context",
        "to": "context",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "Logos",
        "to": "Logos",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "Logos/polynovea-content-studio.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Sasuke102001",
      "repo": "Content_studio",
      "releaseType": "release"
    }
  }
}
